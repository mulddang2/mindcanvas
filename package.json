    "dev:yjs": "node scripts/yjs-server.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "lighthouse": "lhci autorun",
    "prepare": "husky"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@sentry/nextjs": "^8.55.0",
    "@supabase/ssr": "^0.10.3",
