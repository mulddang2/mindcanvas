    "d3": "^7.9.0",
    "framer-motion": "^12.4.7",
    "lucide-react": "^0.475.0",
    "next": "^15.5.4",
    "next-intl": "^4.13.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "ws": "^8.21.0",
    "y-indexeddb": "^9.0.12",
    "y-protocols": "^1.0.7",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.30",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
