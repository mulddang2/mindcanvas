    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.0.6",
    "@types/d3": "^7.4.3",
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/ws": "^8.18.1",
    "concurrently": "^10.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.18",
    "husky": "^9.1.7",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.0.6",
    "typescript": "^5.7.3"
