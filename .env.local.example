# 공유 링크에 박히는 공개 도메인. 비우면 접속 중인 주소를 쓰므로, 인증벽 걸린 git 브랜치 URL이 새어나간다.
NEXT_PUBLIC_SITE_URL=https://mind-canvas-green.vercel.app
# 비우면 프로덕션에서 실시간 협업 비활성(오프라인 단독 편집). 협업 켜려면 배포한 ws 서버 주소(wss://).
NEXT_PUBLIC_YJS_WS_URL=ws://localhost:1234
